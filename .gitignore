# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/

# Node (shouldn't appear, but defensively)
node_modules/

# Build / cache artefacts that must never live inside the plugin tree
.mcpb-cache/
evals/reports/
evals/cache/

# Shipping artefact — the canonical *.plugin file lives inside plugin/
# and IS committed so users can install directly from a checkout.
# Transient build zips elsewhere (versioned artefacts, test bundles)
# should not be committed.
/tmp/
/pluginbuild/
/neomint-toolkit-*.plugin

# Council runtime + iteration state. COUNCIL.md is the skill's
# per-workspace memory file; the review/eval HTMLs and iteration
# summary MDs are transient development output. None of these
# belong in git.
/COUNCIL.md
/COUNCIL-*.md
/council-*.html
/GROUNDING-CACHE.md
