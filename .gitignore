node_modules/

# Build / cache artefacts that must never live inside the plugin tree
.mcpb-cache/
evals/reports/
evals/cache/

# Build artefacts
# ---------------
# The canonical shipping artefact lives at plugin/neomint-toolkit.plugin
# and IS committed so users can install directly from a checkout.
# Everything else — /tmp build scratch directories, versioned release
# bundles that accumulate during iteration, test/throwaway bundles at
# the repo root — stays out of git. Old versions are reachable via git
# tags and GitHub Releases, not by leaving files in the tree.
/tmp/
/pluginbuild/
/neomint-toolkit-*.plugin
/*.plugin
!plugin/neomint-toolkit.plugin

# Skill runtime state
# -------------------
# Files the plugin's own skills write into the working directory when
# they are exercised. When the working directory happens to be this
# repository (which is the case when we dogfood the plugin on itself),
# these land at the repo root. None of them belong in git — they are
# per-workspace memory, per-run caches, or iteration output.
#
# council:
/COUNCIL.md
/COUNCIL-*.md
/GROUNDING-CACHE.md
/council-*.html
/council-*.md
#
# skill-creator iteration + governance grader output:
/ITERATION_REPORT.md
/eval_metadata.json
/skill-creator-*/
/plugin-check-report.json
#
# pdf-umbenennen has no runtime state files (it only renames inputs in
# place), so nothing needed here. If a future skill adds runtime
# state, extend this block rather than inventing a new one.
