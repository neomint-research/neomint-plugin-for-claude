# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/

# Node (shouldn't appear, but defensively)
node_modules/

# Build / cache artefacts that must never live inside the plugin tree
.mcpb-cache/
evals/reports/
evals/cache/

# Build artefacts
# ---------------
# Shipping artefacts live on GitHub Releases, not in the repo.
# *.plugin archives are built on demand in /tmp and uploaded there.
# Nothing named *.plugin should ever live inside the repo.
*.plugin

# Runtime / iteration workspaces
# -------------------------------
# The update-plugin pipeline (and any skill that needs scratch space)
# writes into /tmp/<plugin-name>-workspace/. Never into the repo.
# These names are listed here defensively in case something ever lands.
*-workspace/
iteration-workspace/
skill-snapshot/
eval-viewer-iter*.html

# Session logs / runtime notes that are not source
COUNCIL.md
